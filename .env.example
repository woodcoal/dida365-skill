# 滴答清单 API 配置
# 复制此文件为 .env 并填入实际配置
# Python 版 skill 仅依赖标准库，无需额外安装包。

# OAuth 应用凭据（在 developer.dida365.com/manage 创建应用获取）
DIDA_CLIENT_ID=your_client_id
DIDA_CLIENT_SECRET=your_client_secret

# OAuth 回调端口（默认 18365）
# DIDA_CALLBACK_PORT=18365

# 手动填入 access token（优先级高于 .dida-token.json）
# DIDA_ACCESS_TOKEN=


# 缓存时长（默认 365 分钟）
DIDA_CACHE_MINUTES=365